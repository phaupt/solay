[Unit]
Description=Solar E-Ink Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%DEPLOY_USER%
WorkingDirectory=%DEPLOY_DIR%
EnvironmentFile=%DEPLOY_DIR%/.env.local
ExecStart=%DEPLOY_DIR%/.venv/bin/python main.py --production
Restart=always
RestartSec=10
WatchdogSec=300
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
